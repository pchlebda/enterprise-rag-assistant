# Copy this file to .env and fill in real values.
# .env is git-ignored — never commit secrets.

# ── PostgreSQL ──────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ragdb
DB_USER=raguser
DB_PASSWORD=change_me_in_production

# ── OpenAI ───────────────────────────────────────────────────────────────────
# Not required when running with the local provider profile (default for dev/CI).
OPENAI_API_KEY=sk-...

# ── JWT ──────────────────────────────────────────────────────────────────────
# Minimum 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=change_me_minimum_32_characters_long_please
JWT_ACCESS_EXPIRY_SECONDS=3600
JWT_REFRESH_EXPIRY_SECONDS=86400

# ── Server ───────────────────────────────────────────────────────────────────
SERVER_PORT=8080
